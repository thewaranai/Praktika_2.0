<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#101820"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="P2P Messenger"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvMyIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ваш IP:"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnServer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Создать сервер"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etIp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Введите IP"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:backgroundTint="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnClient"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Подключиться"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnInstructions"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Инструкция"
        android:textSize="18sp"/>

</LinearLayout>